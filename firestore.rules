rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'zeldtradepro@gmail.com';
    }

    // Règle par défaut : tout refuser
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Profils utilisateurs (lookup admin) ──────────────────────────────────────
    match /userEmails/{uid} {
      allow get:  if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow list: if isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.keys().hasOnly(['uid', 'email', 'username', 'lastSeen'])
                   && request.resource.data.uid == uid
                   && request.resource.data.email is string
                   && request.resource.data.email.size() <= 254
                   && request.resource.data.username is string
                   && request.resource.data.username.size() <= 50
                   && request.resource.data.lastSeen is int;
    }

    // ── Codes Pro (hashes) — écriture admin uniquement ───────────────────────────
    match /proCodeHashes/{hash} {
      allow get:  if request.auth != null;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Trades — seuls les champs attendus, limite taille ────────────────────────
    match /users/{userId}/data/trades {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list
                   && request.resource.data.items.size() <= 10000;
    }

    // ── Settings — whitelist stricte des champs, types validés ──────────────────
    match /users/{userId}/data/settings {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['capital', 'contracts', 'instrument'])
                   && request.resource.data.capital is number
                   && request.resource.data.contracts is number
                   && request.resource.data.instrument is string
                   && request.resource.data.instrument.size() <= 20;
    }

    // ── Mes comptes — structure validée ─────────────────────────────────────────
    match /users/{userId}/data/myAccounts {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list
                   && request.resource.data.items.size() <= 100;
    }

    // ── Spreads par firm ─────────────────────────────────────────────────────────
    match /users/{userId}/data/spreadsByFirm {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['apex', 'topstep', 'ftmo', 'lucid']);
    }

    // ── Groupes — structure validée ──────────────────────────────────────────────
    match /users/{userId}/data/groups {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list
                   && request.resource.data.items.size() <= 50;
    }

    // ── AI usage — structure validée, compteur non réductible à même date ───────
    match /users/{userId}/data/aiUsage {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasAll(['date', 'count'])
                   && request.resource.data.keys().hasOnly(['date', 'count'])
                   && request.resource.data.date is string
                   && request.resource.data.date.size() == 10
                   && request.resource.data.count is int
                   && request.resource.data.count >= 0
                   && request.resource.data.count <= 1000
                   && (
                     !exists(/databases/$(database)/documents/users/$(userId)/data/aiUsage)
                     || request.resource.data.date != resource.data.date
                     || request.resource.data.count >= resource.data.count
                   );
    }

    // ── Plan Pro — validation stricte, code lié à l'uid ─────────────────────────
    match /users/{userId}/data/plan {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasAll(['plan', 'activatedAt', 'codeHash'])
                   && request.resource.data.keys().hasOnly(['plan', 'activatedAt', 'codeHash'])
                   && request.resource.data.plan == 'pro'
                   && request.resource.data.activatedAt is int
                   && exists(/databases/$(database)/documents/proCodeHashes/$(request.resource.data.codeHash))
                   && get(/databases/$(database)/documents/proCodeHashes/$(request.resource.data.codeHash)).data.uid == request.auth.uid;
    }
  }
}
