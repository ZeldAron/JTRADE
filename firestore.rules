rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'zeldtradepro@gmail.com'
          && request.auth.token.email_verified == true;
    }

    // Règle par défaut : tout refuser
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Profils utilisateurs (lookup admin) ──────────────────────────────────────
    match /userEmails/{uid} {
      allow get:    if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow list:   if isAdmin();
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow write:  if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'email', 'username', 'lastSeen'])
                    && request.resource.data.uid == uid
                    && request.resource.data.email is string
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.username is string
                    && request.resource.data.username.size() >= 2
                    && request.resource.data.username.size() <= 50
                    // Caractères whitelist : alphanumérique + . _ - + espace (anti-injection email/HTML)
                    && request.resource.data.username.matches('^[A-Za-z0-9._\\- ]+$')
                    // Bloque les pseudos qui usurpent l'admin/staff (lecture admin trompeuse)
                    // SAUF pour le vrai compte admin lui-même (sinon il peut pas créer son userEmails)
                    && (
                      request.auth.token.email == 'zeldtradepro@gmail.com'
                      || !request.resource.data.username.lower().matches('.*(admin|zeldtrade|zeldaron|support|staff|moderator|root|system).*')
                    )
                    && request.resource.data.lastSeen is int;
    }

    // ── Codes Pro (hashes) ───────────────────────────────────────────────────────
    // La génération passe désormais par la Cloud Function `generateProCode` (admin SDK)
    // qui enforce rate-limit + cap + audit log. Plus aucune écriture côté client.
    // Note : `get` autorisé pour le destinataire afin que la rule plan puisse
    // résoudre via `get(...)` lors de l'activation.
    // Self-delete : un user peut delete les codes qui lui sont attribués (utile pour
    // le droit à l'effacement RGPD — un user qui supprime son compte peut purger ses codes).
    match /proCodeHashes/{hash} {
      allow get:    if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow list:   if isAdmin();
      allow create, update: if false;  // CF only
      allow delete: if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // ── Rate-limit admin (writes via Cloud Function uniquement) ─────────────────
    match /adminRateLimit/{action} {
      allow read:   if isAdmin();
      allow write, delete: if false;
    }

    // ── Soft-deleted users (archive 30j avant purge définitive) ─────────────────
    // Écrit par Cloud Function lors d'un deleteUserAccount, accessible admin uniquement
    // pour restauration manuelle dans les 30 jours. Aucun accès client.
    match /deletedUsers/{uid}/{document=**} {
      allow read:   if isAdmin();
      allow write, delete: if false;
    }

    // ── Trades — seuls les champs attendus, limite taille ────────────────────────
    match /users/{userId}/data/trades {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list
                   && request.resource.data.items.size() <= 10000;
    }

    // ── Settings — whitelist stricte des champs, types validés ──────────────────
    match /users/{userId}/data/settings {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['capital', 'contracts', 'instrument'])
                   && request.resource.data.capital is number
                   && request.resource.data.capital >= 0
                   && request.resource.data.capital <= 1000000000
                   && request.resource.data.contracts is number
                   && request.resource.data.contracts >= 1
                   && request.resource.data.contracts <= 999
                   && request.resource.data.instrument is string
                   && request.resource.data.instrument.size() <= 20;
    }

    // ── Mes comptes — 1 max Basic, 100 max Pro ───────────────────────────────────
    match /users/{userId}/data/myAccounts {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin()
                   || (request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.keys().hasOnly(['items'])
                       && request.resource.data.items is list
                       && (
                         request.resource.data.items.size() <= 1
                         || (
                           exists(/databases/$(database)/documents/users/$(userId)/data/plan)
                           && get(/databases/$(database)/documents/users/$(userId)/data/plan).data.plan == 'pro'
                           && request.resource.data.items.size() <= 100
                         )
                       ));
    }

    // ── Clé Groq globale — DEPRECATED, la clé est dans Google Secret Manager ────
    // (anciennement lisible par tout user authentifié — faille corrigée)
    match /config/groq {
      allow read, write: if false;
    }

    // ── Spreads par firm ─────────────────────────────────────────────────────────
    match /users/{userId}/data/spreadsByFirm {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['apex', 'topstep', 'ftmo', 'ftmo1step', 'lucid', 'fpips'])
                   && request.resource.data.size() <= 6;
    }

    // ── Groupes — Pro uniquement ─────────────────────────────────────────────────
    match /users/{userId}/data/groups {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list
                   && request.resource.data.items.size() <= 50
                   && exists(/databases/$(database)/documents/users/$(userId)/data/plan)
                   && get(/databases/$(database)/documents/users/$(userId)/data/plan).data.plan == 'pro';
    }

    // ── AI usage — écriture exclusivement par Cloud Function (admin SDK) ─────────
    // Le client peut LIRE pour afficher son quota, mais NE peut PAS écrire ni
    // supprimer (sinon bypass trivial via DevTools : delete puis recreate à 0).
    match /users/{userId}/data/aiUsage {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if false;
      allow delete: if false;
    }

    // ── Throttle contact (write par Cloud Function uniquement) ──────────────────
    match /users/{userId}/data/contactThrottle {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write, delete: if false;
    }

    // ── Signup notified flag (idempotence Cloud Function notifyNewSignup) ───────
    match /users/{userId}/data/signupNotified {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write, delete: if false;
    }

    // ── Plan Pro — write (create OR update), code consommable une fois, lié à l'uid ─
    // On autorise update pour gérer les cas legacy où un doc plan existe déjà.
    // Le code Pro DOIT être unconsumed (pas de consumedAt sur proCodeHashes) ou
    // déjà consommé par CE même user (réactivation idempotente après reset client).
    match /users/{userId}/data/plan {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
      allow write:  if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['plan', 'activatedAt', 'codeHash'])
                    && request.resource.data.plan == 'pro'
                    && request.resource.data.activatedAt is int
                    && request.resource.data.activatedAt > 1700000000000
                    && request.resource.data.activatedAt <= request.time.toMillis()
                    && request.resource.data.codeHash is string
                    && request.resource.data.codeHash.size() <= 128
                    && exists(/databases/$(database)/documents/proCodeHashes/$(request.resource.data.codeHash))
                    && get(/databases/$(database)/documents/proCodeHashes/$(request.resource.data.codeHash)).data.uid == request.auth.uid;
    }

    // ── Audit logs (immuable, écrit uniquement par Cloud Function admin SDK) ────
    match /auditLogs/{logId} {
      allow read:   if isAdmin();
      allow write, delete: if false;
    }

    // ── Subscription Stripe (read par owner + admin, write par webhook uniquement) ─
    match /users/{userId}/data/stripe {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow write, delete: if false;
    }
  }
}
