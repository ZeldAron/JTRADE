rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'zeldtradepro@gmail.com';
    }

    // Règle par défaut : tout refuser
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Profils utilisateurs (lookup admin) ──────────────────────────────────────
    match /userEmails/{uid} {
      allow get:    if isAdmin() || (request.auth != null && request.auth.uid == uid);
      allow list:   if isAdmin();
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow write:  if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys().hasOnly(['uid', 'email', 'username', 'lastSeen'])
                    && request.resource.data.uid == uid
                    && request.resource.data.email is string
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.username is string
                    && request.resource.data.username.size() <= 50
                    && request.resource.data.lastSeen is int;
    }

    // ── Codes Pro (hashes) — lecture limitée au destinataire (anti-énumération) ──
    match /proCodeHashes/{hash} {
      // Le code est pré-assigné par admin à un uid précis : seul cet uid peut le lire
      allow get:   if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow list:  if isAdmin();
      allow write: if isAdmin();
    }

    // ── Trades — seuls les champs attendus, limite taille ────────────────────────
    match /users/{userId}/data/trades {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list
                   && request.resource.data.items.size() <= 10000;
    }

    // ── Settings — whitelist stricte des champs, types validés ──────────────────
    match /users/{userId}/data/settings {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['capital', 'contracts', 'instrument'])
                   && request.resource.data.capital is number
                   && request.resource.data.capital >= 0
                   && request.resource.data.capital <= 1000000000
                   && request.resource.data.contracts is number
                   && request.resource.data.contracts >= 1
                   && request.resource.data.contracts <= 999
                   && request.resource.data.instrument is string
                   && request.resource.data.instrument.size() <= 20;
    }

    // ── Mes comptes — 1 max Basic, 100 max Pro ───────────────────────────────────
    match /users/{userId}/data/myAccounts {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin()
                   || (request.auth != null
                       && request.auth.uid == userId
                       && request.resource.data.keys().hasOnly(['items'])
                       && request.resource.data.items is list
                       && (
                         request.resource.data.items.size() <= 1
                         || (
                           exists(/databases/$(database)/documents/users/$(userId)/data/plan)
                           && get(/databases/$(database)/documents/users/$(userId)/data/plan).data.plan == 'pro'
                           && request.resource.data.items.size() <= 100
                         )
                       ));
    }

    // ── Clé Groq globale — DEPRECATED, la clé est dans Google Secret Manager ────
    // (anciennement lisible par tout user authentifié — faille corrigée)
    match /config/groq {
      allow read, write: if false;
    }

    // ── Spreads par firm ─────────────────────────────────────────────────────────
    match /users/{userId}/data/spreadsByFirm {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['apex', 'topstep', 'ftmo', 'ftmo1step', 'lucid', 'fpips'])
                   && request.resource.size() < 50000;
    }

    // ── Groupes — Pro uniquement ─────────────────────────────────────────────────
    match /users/{userId}/data/groups {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['items'])
                   && request.resource.data.items is list
                   && request.resource.data.items.size() <= 50
                   && exists(/databases/$(database)/documents/users/$(userId)/data/plan)
                   && get(/databases/$(database)/documents/users/$(userId)/data/plan).data.plan == 'pro';
    }

    // ── AI usage — écriture exclusivement par Cloud Function (admin SDK) ─────────
    // Le client peut LIRE pour afficher son quota, mais NE peut PAS écrire ni
    // supprimer (sinon bypass trivial via DevTools : delete puis recreate à 0).
    match /users/{userId}/data/aiUsage {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write:  if false;
      allow delete: if false;
    }

    // ── Throttle contact (write par Cloud Function uniquement) ──────────────────
    match /users/{userId}/data/contactThrottle {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write, delete: if false;
    }

    // ── Signup notified flag (idempotence Cloud Function notifyNewSignup) ───────
    match /users/{userId}/data/signupNotified {
      allow read:   if request.auth != null && request.auth.uid == userId;
      allow write, delete: if false;
    }

    // ── Plan Pro — create only, code consommable une fois, lié à l'uid ─────────
    match /users/{userId}/data/plan {
      allow read:   if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['plan', 'activatedAt', 'codeHash'])
                    && request.resource.data.plan == 'pro'
                    && request.resource.data.activatedAt is int
                    && request.resource.data.activatedAt > 1700000000000
                    && request.resource.data.activatedAt <= request.time.toMillis()
                    && request.resource.data.codeHash is string
                    && request.resource.data.codeHash.size() <= 128
                    && exists(/databases/$(database)/documents/proCodeHashes/$(request.resource.data.codeHash))
                    && get(/databases/$(database)/documents/proCodeHashes/$(request.resource.data.codeHash)).data.uid == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
